<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KeywordPro — SEO Toolkit</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f8f9fa;color:#1a1a1a;}
header{background:#fff;border-bottom:1px solid #e5e7eb;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-size:22px;font-weight:800;color:#1a1a1a;text-decoration:none;}
.logo span{color:#2563eb;}
.header-right{display:flex;align-items:center;gap:10px;}
.btn-login{padding:8px 18px;font-size:14px;border:1px solid #d1d5db;border-radius:6px;background:#fff;cursor:pointer;color:#374151;}
.btn-signup{padding:8px 18px;font-size:14px;border:none;border-radius:6px;background:#2563eb;color:#fff;cursor:pointer;font-weight:600;}

.hero{background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 50%,#3b82f6 100%);padding:4rem 2rem;text-align:center;color:#fff;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:20px;padding:6px 16px;margin-bottom:1.5rem;font-size:13px;font-weight:600;}
.hero h1{font-size:42px;font-weight:800;margin-bottom:12px;line-height:1.2;}
.hero h1 span{color:#93c5fd;}
.hero p{font-size:18px;opacity:0.85;max-width:560px;margin:0 auto 2rem;line-height:1.6;}
.hero-stats{display:flex;justify-content:center;gap:32px;flex-wrap:wrap;margin-top:2rem;}
.hero-stat{text-align:center;}
.hero-stat-num{font-size:28px;font-weight:800;color:#fff;}
.hero-stat-label{font-size:13px;opacity:0.7;margin-top:2px;}

.main{max-width:1100px;margin:3rem auto;padding:0 1.5rem;}

.section-title{font-size:24px;font-weight:800;margin-bottom:6px;}
.section-sub{font-size:16px;color:#6b7280;margin-bottom:2rem;}

.tools-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-bottom:3rem;}

.tool-card{background:#fff;border:1.5px solid #e5e7eb;border-radius:14px;padding:1.75rem;position:relative;transition:border-color .2s;}
.tool-card:hover{border-color:#2563eb;}
.tool-card.active{border-color:#2563eb;cursor:pointer;}
.tool-card.active:hover{border-color:#1d4ed8;}
.tool-card.coming{opacity:.7;}
.tool-badge{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:1rem;}
.tool-badge.live{background:#dcfce7;color:#15803d;}
.tool-badge.soon{background:#f3f4f6;color:#6b7280;}
.tool-badge.beta{background:#fef3c7;color:#92400e;}
.tool-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:22px;}
.tool-icon.blue{background:#eff6ff;}
.tool-icon.purple{background:#f5f3ff;}
.tool-icon.green{background:#f0fdf4;}
.tool-icon.orange{background:#fff7ed;}
.tool-icon.pink{background:#fdf2f8;}
.tool-icon.teal{background:#f0fdfa;}
.tool-name{font-size:19px;font-weight:700;margin-bottom:6px;}
.tool-desc{font-size:14px;color:#6b7280;line-height:1.6;margin-bottom:1.25rem;}
.tool-features{display:flex;flex-direction:column;gap:5px;margin-bottom:1.5rem;}
.tool-feature{font-size:13px;color:#374151;display:flex;align-items:center;gap:6px;}
.tool-feature span{color:#16a34a;font-weight:700;}
.tool-btn{display:inline-block;padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;text-decoration:none;text-align:center;width:100%;}
.tool-btn.primary{background:#2563eb;color:#fff;}
.tool-btn.primary:hover{background:#1d4ed8;}
.tool-btn.disabled{background:#f3f4f6;color:#9ca3af;cursor:not-allowed;}

.pricing-section{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:2.5rem;margin-bottom:3rem;}
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:1.5rem;}
.price-card{border:1.5px solid #e5e7eb;border-radius:12px;padding:1.5rem;text-align:center;}
.price-card.featured{border-color:#2563eb;background:#eff6ff;}
.price-card.premium{border-color:#7c3aed;background:#f5f3ff;}
.price-name{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#6b7280;margin-bottom:8px;}
.price-card.featured .price-name{color:#1d4ed8;}
.price-card.premium .price-name{color:#6d28d9;}
.price-amount{font-size:32px;font-weight:800;color:#1a1a1a;margin-bottom:4px;}
.price-period{font-size:13px;color:#6b7280;margin-bottom:16px;}
.price-features{text-align:left;display:flex;flex-direction:column;gap:7px;}
.price-feature{font-size:13px;color:#374151;display:flex;align-items:center;gap:6px;}
.price-feature b{color:#16a34a;}
.price-btn{display:block;margin-top:1.25rem;padding:10px;border-radius:8px;font-size:14px;font-weight:600;text-align:center;cursor:pointer;border:none;}
.price-btn.free{background:#f3f4f6;color:#374151;}
.price-btn.blue{background:#2563eb;color:#fff;}
.price-btn.purple{background:#7c3aed;color:#fff;}

.trust-section{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:2rem;margin-bottom:3rem;text-align:center;}
.trust-badges{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-top:1rem;}
.trust-badge{display:flex;align-items:center;gap:8px;font-size:14px;color:#374151;font-weight:500;}
.trust-badge svg{flex-shrink:0;}

footer{text-align:center;padding:2rem;font-size:14px;color:#9ca3af;border-top:1px solid #e5e7eb;line-height:1.8;}
footer a{color:#2563eb;text-decoration:none;}

@media(max-width:768px){
  .hero h1{font-size:28px;}
  .hero p{font-size:15px;}
  .hero-stats{gap:20px;}
  .main{padding:0 1rem;margin:2rem auto;}
  .tools-grid{grid-template-columns:1fr;}
  .pricing-grid{grid-template-columns:1fr;}
}
</style>
</head>
